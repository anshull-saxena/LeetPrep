# Firebase Configuration
# Copy this file to .env.local and fill in your Firebase project values
# Get these values from Firebase Console > Project Settings > General > Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase project values
# Get these from Supabase Dashboard > Settings > API

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Site URL (used for SEO sitemap/robots)
# Set this to your production URL for Vercel
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Google Search Console verification (optional)
# Get this from search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here
